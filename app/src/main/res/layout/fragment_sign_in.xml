<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8FCFD"
    android:gravity="center_horizontal">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="20dp"
        android:background="@mipmap/ic_ai_flood_safe_logo"
        android:padding="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign in"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Name"
        android:textColor="#2D7992"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etSignInName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Enter your name"
        android:padding="12dp"
        android:textSize="14sp"
        android:background="@drawable/edittext_border"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email"
        android:textColor="#2D7992"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etSignInEmail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Enter your email"
        android:padding="12dp"
        android:textSize="14sp"
        android:background="@drawable/edittext_border"
        android:layout_marginBottom="16dp"/>

    <!-- ✅ PASSWORD FIX: Phone input hata kar password field add kar di -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Password"
        android:textColor="#2D7992"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etSignInPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Enter your password"
        android:inputType="textPassword"
        android:padding="12dp"
        android:textSize="14sp"
        android:background="@drawable/edittext_border"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSignIn"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Sign in"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="#2D9CBE"
        app:cornerRadius="10dp"/>

    <TextView
        android:id="@+id/tvGoToSignUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account? Sign up"
        android:textColor="#2D9CBE"
        android:layout_marginTop="24dp"
        android:textStyle="bold"/>

</LinearLayout>